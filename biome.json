{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "useEditorconfig": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    },
    "includes": ["**", "!node_modules/**", "!packages/**/dist/**", "!*.sol"]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "packages/agw-client/**",
        "packages/agw-react/**",
        "packages/agw-web/**",
        "packages/web3-react-agw/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "warn",
            "noAssignInExpressions": "off",
            "noImplicitAnyLet": "warn",
            "noDoubleEquals": "warn"
          },
          "complexity": {
            "noBannedTypes": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "warn"
          }
        }
      }
    },
    {
      "includes": ["examples/**", "apps/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "warn",
            "noArrayIndexKey": "warn",
            "noUnknownAtRules": "off"
          },
          "style": {
            "noNonNullAssertion": "warn"
          },
          "a11y": {
            "noStaticElementInteractions": "warn",
            "noSvgWithoutTitle": "warn"
          },
          "correctness": {
            "useExhaustiveDependencies": "warn"
          }
        }
      }
    },
    {
      "includes": ["packages/agw-core/**", "packages/agw-cli/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "useIterableCallbackReturn": "warn"
          }
        }
      }
    }
  ]
}
