{
  "name": "@abstract-foundation/agw-cli",
  "version": "0.1.6",
  "type": "module",
  "description": "Agent-first CLI for Abstract Global Wallet workflows",
  "license": "MIT",
  "author": "Abstract Foundation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abstract-Foundation/agw-cli.git"
  },
  "homepage": "https://github.com/Abstract-Foundation/agw-cli#readme",
  "bugs": {
    "url": "https://github.com/Abstract-Foundation/agw-cli/issues"
  },
  "bin": {
    "agw-cli": "./dist/index.mjs"
  },
  "files": [
    "dist/",
    "skills/",
    "extensions/"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.mjs",
    "prepublishOnly": "pnpm check-types && pnpm build"
  },
  "devDependencies": {
    "tsdown": "^0.20.3",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@abstract-foundation/agw-client": "workspace:*",
    "@modelcontextprotocol/sdk": "catalog:",
    "commander": "^12.1.0",
    "open": "catalog:",
    "viem": "catalog:"
  }
}
