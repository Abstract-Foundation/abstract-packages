{
  "name": "@abstract-foundation/web3-react-agw",
  "description": "Abstract Global Wallet for web3-react",
  "version": "1.8.3",
  "scripts": {
    "build": "pnpm run clean && pnpm run build:esm+types && pnpm run build:cjs",
    "build:esm+types": "tsc --outDir ./dist/esm --declaration --declarationMap --declarationDir ./dist/types && printf '{\"type\":\"module\"}' > ./dist/esm/package.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && printf '{\"type\":\"commonjs\"}' > ./dist/cjs/package.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "debug": "tsc-watch --sourceMap true --outDir ./dist/esm --declaration --declarationMap --declarationDir ./dist/types",
    "test:build": "publint && attw --pack --ignore-rules false-cjs"
  },
  "keywords": [
    "eth",
    "ethereum",
    "smart-account",
    "abstract",
    "account-abstraction",
    "global-wallet",
    "wallet",
    "web3",
    "web3-react"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abstract-Foundation/abstract-packages.git",
    "directory": "packages/web3-react-agw"
  },
  "bugs": {
    "url": "https://github.com/Abstract-Foundation/abstract-packages/issues"
  },
  "homepage": "https://github.com/Abstract-Foundation/abstract-packages/tree/main/packages/web3-react-agw",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "typings": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": ">=5.0.4"
  },
  "dependencies": {
    "@abstract-foundation/agw-client": "workspace:^",
    "@privy-io/cross-app-connect": "^0.5.2",
    "@web3-react/types": "^8.2.3"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.80.3",
    "@types/node": "catalog:",
    "@web3-react/core": "^8.2.3",
    "@web3-react/store": "^8.2.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "viem": "catalog:",
    "wagmi": "catalog:"
  }
}
